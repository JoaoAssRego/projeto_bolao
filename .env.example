# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase.
# Encontre estes valores em: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# --- Sincronismo automático de resultados (opcional) ---
# O token da football-data.org NÃO vai aqui (não pode ir pro frontend).
# Ele fica como SEGREDO da Edge Function no Supabase:
#   supabase secrets set FOOTBALL_DATA_TOKEN=seu_token
# Pegue o token grátis em https://www.football-data.org/client/register
# Setup completo no README, seção "Sincronismo automático de resultados".
